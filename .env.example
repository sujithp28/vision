# Application Settings
APP_NAME=VisionForge AI
APP_VERSION=0.1.0
DEBUG=False
ENVIRONMENT=development  # Options: development, staging, production, test

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False  # Enable auto-reload (development only)
API_WORKERS=1

# LLM Settings
LLM_PROVIDER=openai  # Options: openai, anthropic, ollama, etc.
LLM_API_KEY=  # API key for the LLM provider (if not using provider-specific key)
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
# LLM_EXTRA_CONFIG: Additional provider-specific configuration (JSON format)
# Example: LLM_EXTRA_CONFIG={"organization": "org-id", "base_url": "https://api.example.com"}

# Database Settings
DATABASE_URL=sqlite:///./visionforge.db
DATABASE_ECHO=False  # Enable SQL query logging

# Cache Settings
REDIS_URL=  # Redis URL for caching (optional, e.g., redis://localhost:6379)
CACHE_TTL=3600  # Default cache TTL in seconds

# Storage Settings
STORAGE_TYPE=local  # Options: local, s3, gcs, azure
STORAGE_PATH=./storage  # Local storage path or bucket name
STORAGE_BUCKET=  # Cloud storage bucket name (for S3, GCS, Azure)

# Security Settings
SECRET_KEY=your-secret-key-here  # Change this in production!
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload Settings
MAX_UPLOAD_SIZE=104857600  # 100 MB in bytes
# ALLOWED_FILE_TYPES: List of allowed MIME types (comma-separated)
# Example: ALLOWED_FILE_TYPES=image/jpeg,image/png,video/mp4,text/plain,application/pdf
UPLOAD_DIRECTORY=./uploads

# Output Settings
OUTPUT_DIRECTORY=./output
TEMP_DIRECTORY=./tmp

# Logging Settings
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# CORS Settings
# CORS_ORIGINS: List of allowed origins (comma-separated)
# Example: CORS_ORIGINS=http://localhost:3000,https://example.com
CORS_ORIGINS=*

# External Service APIs
OPENAI_API_KEY=  # Get from https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=  # Get from https://console.anthropic.com/
ELEVENLABS_API_KEY=  # Get from https://elevenlabs.io/
RUNWAY_API_KEY=  # Get from https://runwayml.com/
SUNO_API_KEY=  # Get from https://suno.ai/

# Feature Flags
ENABLE_USAGE_TRACKING=True
ENABLE_CONTENT_MODERATION=False
ENABLE_CACHING=True